<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
.sidebar {
    height: 100vh;
    background: #343a40;
    color: white;
    padding: 20px;
}
.card {
    margin: 10px;
}
</style>
</head>

<body>
<div class="container-fluid">
<div class="row">

<div class="col-md-2 sidebar">
<h4>Dashboard</h4>
<ul>
<li>Home</li>
<li>Users</li>
<li>Reports</li>
</ul>
</div>

<div class="col-md-10">
<h2 class="mt-3">Statistics</h2>

<div class="row">
<div class="col-md-3">
<div class="card bg-primary text-white">
<div class="card-body">Users: 120</div>
</div>
</div>

<div class="col-md-3">
<div class="card bg-success text-white">
<div class="card-body">Sales: ₹5000</div>
</div>
</div>

<div class="col-md-3">
<div class="card bg-warning text-white">
<div class="card-body">Orders: 75</div>
</div>
</div>
</div>

</div>
</div>
</div>
</body>
</html>
