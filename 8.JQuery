<!DOCTYPE html>
<html>
<head>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>

<body>

<input type="text" id="user"><br>
<input type="password" id="pass"><br>
<button id="btn">Login</button>

<p id="msg"></p>

<script>
$("#btn").click(function(){
    let u = $("#user").val();
    let p = $("#pass").val();

    if(u === "admin" && p === "1234") {
        $("#msg").text("Login Successful");
    } else {
        $("#msg").text("Invalid");
    }
});
</script>

</body>
</html>
